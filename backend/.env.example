# ---- Metabase (data source) ----
METABASE_URL=https://metabase.kaip.in
METABASE_USER_EMAIL=pawan.kumar@blitzscale.co
METABASE_PASSWORD=your-metabase-password

# ---- Claude (AI plan generator) ----
# Option A: direct Anthropic — key from https://console.anthropic.com (Settings -> API keys)
# Option B: a proxy (e.g. LiteLLM) — set ANTHROPIC_BASE_URL to the proxy and use its key.
ANTHROPIC_BASE_URL=https://litellm.blitzshopdeck.in
ANTHROPIC_API_KEY=sk-...
# Model: claude-opus-4-8 (smartest) / claude-sonnet-4-6 (fast/cheap)
CLAUDE_MODEL=claude-opus-4-8
# Multi-agent plan uses 6 calls (analyst + 4 specialists + synthesizer). To cut cost/budget,
# run the specialists on a cheaper model and keep the synthesizer on Opus:
#   SPECIALIST_MODEL=claude-sonnet-4-6
#   ANALYST_MODEL=claude-sonnet-4-6
#   SYNTH_MODEL=claude-opus-4-8
# (all default to CLAUDE_MODEL if unset)

# ---- Team-shared AI memory (Upstash Redis, free tier) ----
# Create a free DB at https://console.upstash.com -> Redis -> Create database,
# then copy the REST URL + REST TOKEN here. Without these, memory falls back to per-browser localStorage.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- server ----
PORT=8000
